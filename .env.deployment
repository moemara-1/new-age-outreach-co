# ==========================================
# New Age Pipeline — Production Cloud Keys
# ==========================================
# Use this file to organize all your cloud deployment keys.
# You will copy these values into Vercel and Render's Environment Variables settings.

# 1. Neon.tech (PostgreSQL Database)
# Format: postgresql://[user]:[password]@[host]/neondb?sslmode=require
DATABASE_URL="postgresql://neondb_owner:npg_T2nNlyOGVYk8@ep-dawn-waterfall-aheafif9-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# 2. Redis Cloud (Or Aiven) (Redis Queue)
# Format: redis://default:[password]@[host]:[port]
REDIS_URL=""

# 3. Koyeb (SearXNG Web Search)
# Format: https://[your-app-name]-[your-org].koyeb.app
SEARXNG_URL=""

# 4. Vercel (Next.js Application URL)
# Format: https://[your-project-name].vercel.app
# Note: Leave this blank in Vercel during the VERY FIRST deployment! Add it afterwards.
NEXT_PUBLIC_APP_URL=""


# ------------------------------------------
# External API Providers
# ------------------------------------------

# OpenRouter (For standard LLMs like Llama 3)
OPENROUTER_API_KEY=""

# Groq (Optional, for extremely fast standard LLMs)
GROQ_API_KEY=""

# MiniMax (CRITICAL for Builder Agent premium websites)
# Format: eyJhbGci...
MINIMAX_API_KEY=""

# Google Maps API (From Google Cloud Console)
GOOGLE_MAPS_API_KEY=""


# ------------------------------------------
# Resend (Email Outreach)
# ------------------------------------------

# Your master Resend tracking key
RESEND_API_KEY=""

# The verified email address you will send from
RESEND_FROM_EMAIL="Max <outreach@yourdomain.com>"

# The webhook secret you will get AFTER adding your Vercel URL to the Resend Webhooks page
# Format: whsec_...
RESEND_WEBHOOK_SECRET=""
